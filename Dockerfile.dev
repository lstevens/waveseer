# Development Dockerfile for Waveseer
FROM python:3.10-slim

# Set environment variables
ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PYTHONPATH=/app \
    WAVESEER_MODELS_DIR=/app/models

# Set working directory
WORKDIR /app

# Install system dependencies including development tools
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    git \
    curl \
    tini \
    && rm -rf /var/lib/apt/lists/*

# Copy requirements first for better layer caching
COPY requirements.txt requirements-dev.txt ./

# Install dependencies including development packages
RUN pip install --no-cache-dir -r requirements.txt \
    && pip install --no-cache-dir -r requirements-dev.txt \
    && pip install --no-cache-dir pytest pytest-cov black isort mypy

# Create directory structure
RUN mkdir -p /app/models /app/data /app/logs

# We don't copy the source code here - it will be mounted as a volume

# Development port
EXPOSE 9000

# Use tini as init system to handle signals properly
ENTRYPOINT ["/usr/bin/tini", "--"]

# Default command: run the API server with hot reload
CMD ["uvicorn", "wave.api.app:app", "--host", "0.0.0.0", "--port", "9000", "--reload"]
